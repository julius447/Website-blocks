{"content": [{"id": "aphhdr", "name": "section", "parent": 0, "children": ["aphcd0"], "settings": {"_padding": {"top": "0", "bottom": "0", "left": "0", "right": "0"}, "_margin": {"top": "0"}, "_width": "100%", "_position": "relative", "_top": "0", "_zIndex": "99999999"}, "label": "Ampy Header"}, {"id": "aphcd0", "name": "code", "parent": "aphhdr", "children": [], "settings": {"code": "<style>\n/* ============================================================================\n   Ampy Header — production CSS (FluentSnippets: CSS Snippet, Frontend / wp_head)\n   FORMAT ONLY — byte-equivalent to the approved prototype. rem→px at 1rem=10px.\n   Everything is scoped under .ampy-hdr-root so the header cannot restyle the page\n   and the theme cannot restyle the header. Two rules are legitimately global\n   because a FIXED header must offset the page + lock scroll — flagged below.\n   Self-host Outfit: upload the 6 woff2 to /wp-content/uploads/ampy-fonts/.\n   ============================================================================ */\n@font-face{font-family:\"Outfit\";font-style:normal;font-weight:300;font-display:swap;src:url(\"/wp-content/uploads/ampy-fonts/Outfit-Light.woff2\") format(\"woff2\");}\n@font-face{font-family:\"Outfit\";font-style:normal;font-weight:400;font-display:swap;src:url(\"/wp-content/uploads/ampy-fonts/Outfit-Regular.woff2\") format(\"woff2\");}\n@font-face{font-family:\"Outfit\";font-style:normal;font-weight:500;font-display:swap;src:url(\"/wp-content/uploads/ampy-fonts/Outfit-Medium.woff2\") format(\"woff2\");}\n@font-face{font-family:\"Outfit\";font-style:normal;font-weight:600;font-display:swap;src:url(\"/wp-content/uploads/ampy-fonts/Outfit-SemiBold.woff2\") format(\"woff2\");}\n@font-face{font-family:\"Outfit\";font-style:normal;font-weight:700;font-display:swap;src:url(\"/wp-content/uploads/ampy-fonts/Outfit-Bold.woff2\") format(\"woff2\");}\n@font-face{font-family:\"Outfit\";font-style:normal;font-weight:800;font-display:swap;src:url(\"/wp-content/uploads/ampy-fonts/Outfit-ExtraBold.woff2\") format(\"woff2\");}\n\n/* --- the ONE required global: offset page content below the fixed bar --- */\nbody{padding-top:76px}\n@media (max-width:992px){body{padding-top:66px}}\nbody.aph-open{overflow:hidden}   /* scroll-lock fallback; JS also position-fixes the body on iOS */\n\n/* --- wrapper: design tokens + the header's own text defaults --- */\n.ampy-hdr-root{\n  --ap-navy:#090b32; --ap-teal:#00a991; --ap-teal-hover:#008d79;\n  --ap-green:#39c281; --ap-mint:#55ff9a; --ap-offwhite:#f5f9ff; --ap-white:#fff;\n  --ink:#0f123c; --ink-muted:#565e82; --ink-faint:#6a7190;\n  --line:rgba(15,18,60,.10); --line-soft:rgba(15,18,60,.06); --hairline:#dbe4f0;\n  --font:\"Outfit\",system-ui,-apple-system,sans-serif;\n  --r-sm:8px; --r-md:14px; --r-lg:20px; --r-btn:15px; --t:.2s ease-out;\n  --header-h:76px; --wrap:28px; --container:1280px;\n  font-family:var(--font); font-weight:300; color:var(--ink);\n  line-height:1.5; font-size:16px; -webkit-font-smoothing:antialiased;\n}\n.ampy-hdr-root *{box-sizing:border-box; margin:0; padding:0; -webkit-tap-highlight-color:transparent}\n\n.ampy-hdr-root a{color:inherit;text-decoration:none}\n.ampy-hdr-root img, .ampy-hdr-root svg{display:block;max-width:100%}\n.ampy-hdr-root button{font-family:inherit;cursor:pointer;border:0;background:none;color:inherit}\nbody.aph-open{overflow:hidden}\n.ampy-hdr-root :focus-visible{outline:3px solid var(--ap-navy);outline-offset:2px;border-radius:6px}\n.ampy-hdr-root .dim{position:fixed;inset:0;background:rgba(9,11,50,.20);opacity:0;pointer-events:none;\n  transition:opacity var(--t);z-index:60}\nbody.aph-menu .ampy-hdr-root .dim, body.aph-open .ampy-hdr-root .dim{opacity:1;pointer-events:auto}\n.ampy-hdr-root .hdr{position:fixed;top:0;left:0;width:100%;height:var(--header-h);z-index:100;\n  background:var(--ap-offwhite);\n  border-bottom:1px solid var(--hairline);\n  box-shadow:0 4px 14px -10px rgba(15,18,60,.14)}\nbody.aph-menu .ampy-hdr-root .hdr{border-bottom-color:transparent}\n.ampy-hdr-root .hdr__in{max-width:var(--container);margin:0 auto;height:100%;display:flex;align-items:center;\n  padding-left:max(var(--wrap),env(safe-area-inset-left));\n  padding-right:max(var(--wrap),env(safe-area-inset-right))}\n.ampy-hdr-root .hdr__logo{flex:0 0 auto;display:flex;align-items:center}\n.ampy-hdr-root .hdr__logo img{width:130px;height:auto}\n.ampy-hdr-root .nav{flex:1 1 auto;display:flex;justify-content:center;gap:10px;height:100%}\n.ampy-hdr-root .nav__item{height:100%}\n.ampy-hdr-root .nav__link{display:inline-flex;align-items:center;gap:8px;height:100%;padding:0 26px;\n  font-size:18px;font-weight:500;color:var(--ink);\n  border-bottom:2px solid transparent;margin-bottom:-2px;\n  transition:background var(--t),border-color var(--t)}\n.ampy-hdr-root .nav__link .chev{width:13px;height:13px;opacity:.55;transition:transform var(--t),opacity var(--t)}\n.ampy-hdr-root .nav__item.open .nav__link{background:rgba(0,169,145,.09);border-color:var(--ap-teal)}\n.ampy-hdr-root .nav__item.open .chev{transform:rotate(180deg);opacity:1}\n@media (hover:hover) and (pointer:fine){\n.ampy-hdr-root .nav__item:hover .nav__link{background:rgba(0,169,145,.09);border-color:var(--ap-teal)}.ampy-hdr-root .nav__item:hover .chev{transform:rotate(180deg);opacity:1}}\n\n.ampy-hdr-root .hdr__right{flex:0 0 auto;margin-left:auto;display:flex;align-items:center;gap:16px}\n.ampy-hdr-root .cta{position:relative;display:inline-flex;align-items:center;height:48px;padding:0 26px;\n  border-radius:var(--r-btn);font-size:16px;font-weight:600;color:#fff;\n  background:var(--ap-teal);box-shadow:0 4px 12px -5px rgba(0,169,145,.5);\n  transition:background var(--t)}\n.ampy-hdr-root .cta:hover{background:var(--ap-teal-hover)}\n.ampy-hdr-root .cta::after{content:\"\";width:10px;height:10px;border-radius:50%;background:var(--ap-mint);\n  position:absolute;bottom:-5px;left:calc(50% - 5px);\n  animation:aph-cta_dot 1.6s ease-in-out infinite}\n@keyframes aph-cta_dot{\n  0%{box-shadow:0 0 rgba(85,255,154,.4)}\n  50%{box-shadow:0 0 3px 6px rgba(85,255,154,.55)}\n  100%{box-shadow:0 0 6px 9px rgba(85,255,154,0)}}\n.ampy-hdr-root .burger{display:none;position:relative;width:46px;height:46px;flex-direction:column;\n  justify-content:center;align-items:center;gap:5px}\n.ampy-hdr-root .burger span:not(.burger__close){display:block;width:24px;height:3px;border-radius:3px;\n  background:var(--ap-navy);transition:opacity var(--t)}\n.ampy-hdr-root .burger .burger__close{position:absolute;inset:0;border-radius:var(--r-md);background:#e7ecf4;\n  display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;\n  transition:opacity var(--t)}\n.ampy-hdr-root .burger__close svg{width:18px;height:18px;color:#3c4260}\nbody.aph-open .ampy-hdr-root .burger span:not(.burger__close){opacity:0}\nbody.aph-open .ampy-hdr-root .burger .burger__close{opacity:1;animation:aph-scale_in .3s ease-out}\n@keyframes aph-scale_in{0%{transform:scale(.9)}100%{transform:scale(1)}}\n.ampy-hdr-root .mega{position:fixed;left:0;right:0;top:var(--header-h);z-index:90;\n  background:var(--ap-offwhite);border-bottom:1px solid var(--hairline);\n  box-shadow:0 22px 36px -28px rgba(15,18,60,.20);\n  max-height:calc(100vh - var(--header-h));max-height:calc(100dvh - var(--header-h));\n  overflow-y:auto;overscroll-behavior:contain;\n  visibility:hidden;opacity:0;pointer-events:none;\n  transition:opacity var(--t),visibility 0s .2s}\n.ampy-hdr-root .nav__item.open .mega{visibility:visible;opacity:1;pointer-events:auto;\n  transition:opacity var(--t),visibility 0s}\n.ampy-hdr-root .mega__in{max-width:var(--container);margin:0 auto;padding:36px var(--wrap);\n  display:flex;flex-wrap:wrap;row-gap:32px}\n.ampy-hdr-root .mega--services .mega__in{display:grid;grid-template-columns:repeat(4,1fr);column-gap:0}\n.ampy-hdr-root .mcol{min-width:0;padding-right:24px}\n.ampy-hdr-root .mcol+.mcol{padding-left:24px;border-left:1px solid var(--line)}\n.ampy-hdr-root .mcol__title{display:flex;align-items:center;gap:10px;font-size:18px;font-weight:600;color:var(--ink);\n  padding:2px 0 2px;margin-bottom:12px}\n.ampy-hdr-root .mcol__title img{width:22px;height:22px;object-fit:contain}\n.ampy-hdr-root a.mcol__title:hover{color:var(--ap-teal)}\n.ampy-hdr-root .mitem{display:block;font-size:15.5px;font-weight:400;color:var(--ink-muted);\n  padding:7px 11px;border-radius:var(--r-sm);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\n  transition:color var(--t),background var(--t)}\n.ampy-hdr-root .mitem:hover{color:var(--ap-teal);background:rgba(0,169,145,.06)}\n.ampy-hdr-root .mitem span{display:block;font-size:13.5px;color:var(--ink-faint);margin-top:1px;\n  white-space:nowrap;overflow:hidden;text-overflow:ellipsis}\n.ampy-hdr-root .mitem:hover span{color:var(--ink-muted)}\n.ampy-hdr-root .mega--products .mega__in{max-width:1040px;align-items:center}\n.ampy-hdr-root .pzone{flex:1 1 60%;min-width:0;display:flex;flex-direction:column;gap:12px}\n.ampy-hdr-root .ptile{display:flex;align-items:center;gap:20px;padding:14px;border-radius:var(--r-lg);\n  transition:background var(--t)}\n.ampy-hdr-root .ptile:hover{background:rgba(0,169,145,.06)}\n.ampy-hdr-root .ptile__img{flex:0 0 auto;width:170px;height:124px;border-radius:var(--r-md);\n  background:var(--ap-white);border:1px solid var(--line-soft);overflow:hidden;\n  display:flex;align-items:center;justify-content:center;box-shadow:0 4px 12px -6px rgba(15,18,60,.14)}\n.ampy-hdr-root .ptile__img img{width:100%;height:100%;object-fit:cover}\n.ampy-hdr-root .ptile__t strong{display:block;font-size:21px;font-weight:600;color:var(--ink)}\n.ampy-hdr-root .ptile__t em{display:block;font-style:normal;font-size:15px;color:var(--ink-muted);margin-top:3px}\n.ampy-hdr-root .ptile .go{margin-left:auto;color:var(--ap-teal);opacity:.35;font-size:20px;\n  transition:opacity var(--t),transform var(--t)}\n.ampy-hdr-root .ptile:hover .go{opacity:1;transform:translateX(3px)}\n.ampy-hdr-root .gzone{flex:0 0 260px;border-left:1px solid var(--line);padding-left:30px;margin-left:24px;\n  display:flex;flex-direction:column;justify-content:center}\n.ampy-hdr-root .gzone__label{font-size:12.5px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;\n  color:var(--ink-faint);margin-bottom:12px}\n.ampy-hdr-root .gitem{display:block;font-size:16px;color:var(--ink-muted);padding:9px 0;transition:color var(--t)}\n.ampy-hdr-root .gitem:hover{color:var(--ap-teal)}\n.ampy-hdr-root .mega--solutions .mega__in{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;\n  padding-top:40px;padding-bottom:40px}\n.ampy-hdr-root .lcard{position:relative;border-radius:var(--r-lg);overflow:hidden;min-height:230px;\n  display:flex;align-items:flex-end;box-shadow:0 8px 24px -10px rgba(15,18,60,.25);\n  transition:transform .25s ease-out,box-shadow .25s ease-out}\n.ampy-hdr-root .lcard:hover{transform:translateY(-4px);box-shadow:0 16px 36px -12px rgba(15,18,60,.35)}\n.ampy-hdr-root .lcard img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;\n  transition:transform .45s ease-out}\n.ampy-hdr-root .lcard:hover img{transform:scale(1.05)}\n.ampy-hdr-root .lcard::before{content:\"\";position:absolute;inset:0;opacity:.92;\n  background:linear-gradient(183deg,rgba(9,11,50,.04) 30%,rgba(9,11,50,.84));z-index:1;transition:opacity var(--t)}\n.ampy-hdr-root .lcard:hover::before{opacity:1}\n.ampy-hdr-root .lcard__t{position:relative;z-index:2;padding:20px;width:100%}\n.ampy-hdr-root .lcard__row{display:flex;align-items:flex-end;justify-content:space-between;gap:10px}\n.ampy-hdr-root .lcard h4{font-size:20px;font-weight:600;color:#fff;letter-spacing:-.01em;text-shadow:0 1px 6px rgba(9,11,50,.5)}\n.ampy-hdr-root .lcard p{font-size:14px;color:#fff;margin-top:3px;font-weight:400;line-height:1.35;text-shadow:0 1px 5px rgba(9,11,50,.55)}\n.ampy-hdr-root .lcard .go{flex:0 0 auto;width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,.16);\n  -webkit-backdrop-filter:blur(4px);backdrop-filter:blur(4px);border:1px solid rgba(255,255,255,.25);\n  display:flex;align-items:center;justify-content:center;color:#fff;font-size:17px;\n  transition:background var(--t),transform var(--t)}\n.ampy-hdr-root .lcard:hover .go{background:var(--ap-teal);border-color:transparent;transform:translateX(3px)}\n.ampy-hdr-root .drawer{position:fixed;top:var(--header-h);right:0;z-index:95;\n  height:calc(100vh - var(--header-h));height:calc(100dvh - var(--header-h));\n  width:min(100%,440px);background:var(--ap-white);\n  transform:translateX(100%);opacity:0;pointer-events:none;visibility:hidden;\n  transition:transform var(--t),opacity var(--t),visibility 0s var(--t);\n  overflow-y:auto;overscroll-behavior:contain;-webkit-overflow-scrolling:touch;\n  display:flex;flex-direction:column}\nbody.aph-open .ampy-hdr-root .drawer{transform:translateX(0);opacity:1;pointer-events:auto;visibility:visible;\n  transition:transform var(--t),opacity var(--t),visibility 0s}\n.ampy-hdr-root .drawer__eyebrow{font-size:11px;font-weight:400;letter-spacing:.1em;text-transform:uppercase;\n  color:#73757d;padding:32px 20px 8px}\n.ampy-hdr-root .drawer__list{padding:0 20px}\n.ampy-hdr-root .acc__head{width:100%;display:flex;align-items:center;justify-content:space-between;\n  padding:15px 0;font-size:19px;font-weight:400;color:#14151a;text-align:left;\n  border-bottom:1px solid #d5d5dc}\n.ampy-hdr-root .acc__head .chev{width:16px;height:16px;color:currentColor;opacity:.65;transition:transform var(--t)}\n.ampy-hdr-root .acc.open>.acc__head .chev{transform:rotate(180deg);opacity:1}\n.ampy-hdr-root .acc__body{max-height:0;overflow:hidden;transition:max-height .28s ease-out}\n.ampy-hdr-root .acc--sub{padding-left:14px}\n.ampy-hdr-root .acc--sub .acc__head{padding:15px 0;font-size:18px;font-weight:500;color:#14151a;\n  border-bottom:1px solid rgba(0,0,0,.2)}\n.ampy-hdr-root .acc--sub .acc__head .ttl{display:flex;align-items:center;gap:14px}\n.ampy-hdr-root .acc--sub .acc__head .ttl img{width:24px;height:24px;object-fit:contain}\n.ampy-hdr-root .m-item{display:block;padding:10px 0 10px 38px;font-size:16px;font-weight:400;color:#14151a;\n  border-bottom:1px solid #d5d5dc}\n.ampy-hdr-root .m-item:active{background:rgba(0,169,145,.06);color:var(--ap-teal)}\n.ampy-hdr-root .m-item span{display:block;font-size:13px;color:var(--ink-faint)}\n.ampy-hdr-root .m-prodwrap{padding-left:14px}\n.ampy-hdr-root .m-prod{display:flex;align-items:center;gap:16px;padding:16px 0;\n  border-bottom:1px solid rgba(0,0,0,.2)}\n.ampy-hdr-root .m-prod__img{flex:0 0 auto;width:50px;height:50px;border-radius:10px;overflow:hidden;\n  background:var(--ap-white);border:1px solid var(--line-soft)}\n.ampy-hdr-root .m-prod__img img{width:100%;height:100%;object-fit:cover}\n.ampy-hdr-root .m-prod__name{font-size:18px;font-weight:500;color:#14151a}\n.ampy-hdr-root .m-prod__arr{margin-left:auto;width:15px;height:15px;color:#9a9aa0;flex:0 0 auto}\n.ampy-hdr-root .m-sub-label{display:block;font-size:11px;font-weight:400;letter-spacing:.1em;text-transform:uppercase;\n  color:#73757d;margin:32px 0 8px}\n.ampy-hdr-root .m-sub{display:block;padding:10px 0;font-size:16px;font-weight:400;color:#14151a;\n  border-bottom:1px solid #d5d5dc}\n.ampy-hdr-root .m-sub:active{color:var(--ap-teal)}\n.ampy-hdr-root .drawer__foot{margin-top:12px;padding:20px 20px calc(24px + env(safe-area-inset-bottom))}\n.ampy-hdr-root .drawer__cta{display:flex;align-items:center;justify-content:center;gap:10px;\n  height:56px;border-radius:var(--r-btn);background:var(--ap-teal);color:#fff;\n  font-size:18px;font-weight:600;transition:background var(--t)}\n.ampy-hdr-root .drawer__cta:active{background:var(--ap-teal-hover)}\n.ampy-hdr-root .drawer__cta svg{width:20px;height:20px;flex:0 0 auto}\n@media (max-width:1080px){\n.ampy-hdr-root .mega--solutions .mega__in{grid-template-columns:repeat(2,1fr)}.ampy-hdr-root .mega--products .mega__in{max-width:none}}\n\n@media (max-width:992px){\n.ampy-hdr-root{--header-h:66px}.ampy-hdr-root .nav{display:none}.ampy-hdr-root .burger{display:flex}.ampy-hdr-root .cta{height:42px;padding:0 19px;font-size:15px}}\n\n@media (min-width:993px){\n.ampy-hdr-root .drawer{display:none}}\n\n@media (max-width:560px){\n.ampy-hdr-root .hdr__logo img{width:100px}.ampy-hdr-root{--wrap:16px}}\n\n@media (max-width:400px){\n.ampy-hdr-root .cta{font-size:13.5px;padding:0 15px;height:44px}}\n\n@media (max-width:374px){\n.ampy-hdr-root .hdr__logo img{width:84px}.ampy-hdr-root .hdr__right{gap:10px}.ampy-hdr-root .cta{font-size:13px;padding:0 12px}}\n\n@media (max-width:339px){\n.ampy-hdr-root{--wrap:12px}.ampy-hdr-root .hdr__logo img{width:76px}.ampy-hdr-root .hdr__right{gap:8px}.ampy-hdr-root .cta{font-size:12px;padding:0 10px;height:40px}}\n\n@media (pointer:coarse){\n.ampy-hdr-root .mitem{padding-top:12px;padding-bottom:12px}.ampy-hdr-root .gitem{padding:12px 0}}\n\n@media (min-width:1700px){\n.ampy-hdr-root .mega{left:50%;right:auto;transform:translateX(-50%);width:min(100vw,1480px);\n    border:1px solid var(--hairline);border-top:0;border-radius:0 0 var(--r-lg) var(--r-lg)}}\n\n@media (prefers-reduced-motion:reduce){\n.ampy-hdr-root *{animation:none!important;transition:none!important}}\n\n</style>\n<div class=\"ampy-hdr-root\">\n  <div class=\"dim\" data-close></div>\n\n  <!-- ============================ HEADER ============================ -->\n  <header class=\"hdr\">\n    <div class=\"hdr__in\">\n      <a class=\"hdr__logo\" href=\"https://ampy.se\" aria-label=\"Ampy — hem\">\n        <img src=\"https://ampy.se/wp-content/uploads/Ampy-logo.svg\" alt=\"Ampy\">\n      </a>\n\n      <nav class=\"nav\" aria-label=\"Huvudmeny\">\n\n        <!-- TJÄNSTER -->\n        <div class=\"nav__item\" data-menu>\n          <button class=\"nav__link\" aria-expanded=\"false\" aria-controls=\"aph-mega-tjanster\">Tjänster\n            <svg class=\"chev\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><path d=\"M6 9l6 6 6-6\"/></svg>\n          </button>\n          <div class=\"mega mega--services\" id=\"aph-mega-tjanster\">\n            <div class=\"mega__in\">\n              <div class=\"mcol\">\n                <a class=\"mcol__title\" href=\"https://ampy.se/elinstallation/\">\n                  <img src=\"https://ampy.se/wp-content/uploads/Shovel-icon.svg\" alt=\"\">Elinstallationer</a>\n                <a class=\"mitem\" href=\"https://ampy.se/elservice/elcentral/\">Byte av elcentral</a>\n                <a class=\"mitem\" href=\"https://ampy.se/elservice/elbesiktning/\">Elbesiktning</a>\n                <a class=\"mitem\" href=\"https://ampy.se/elservice/felsokning-av-el/\">Felsökning av el</a>\n                <a class=\"mitem\" href=\"https://ampy.se/elservice/jordfelsbrytare/\">Jordfelsbrytare</a>\n                <a class=\"mitem\" href=\"https://ampy.se/elservice/lastbalansering/\">Lastbalansering</a>\n                <a class=\"mitem\" href=\"https://ampy.se/elservice/smarta-hem/\">Smarta hem</a>\n              </div>\n              <div class=\"mcol\">\n                <a class=\"mcol__title\" href=\"https://ampy.se/elservice/belysning/\">\n                  <img src=\"https://ampy.se/wp-content/uploads/light-bulb.svg\" alt=\"\">Belysning</a>\n                <a class=\"mitem\" href=\"https://ampy.se/elservice/inomhusbelysning/\">Inomhusbelysning</a>\n                <a class=\"mitem\" href=\"https://ampy.se/elservice/utomhusbelysning/\">Utomhusbelysning</a>\n                <a class=\"mitem\" href=\"https://ampy.se/elservice/spotlights/\">Installation av spotlights</a>\n                <a class=\"mitem\" href=\"https://ampy.se/elservice/strombrytare/\">Byte av strömbrytare</a>\n                <a class=\"mitem\" href=\"https://ampy.se/elservice/glodlampa/\">Byte av ljuskällor</a>\n              </div>\n              <div class=\"mcol\">\n                <span class=\"mcol__title\">\n                  <img src=\"https://ampy.se/wp-content/uploads/window.svg\" alt=\"\">Kök &amp; badrum</span>\